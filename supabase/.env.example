# Supabase — Playbook
# Copy to .env and fill in values from your Supabase project dashboard
# Project Settings → API  (for URL and anon key)
# Project Settings → Database (for password)

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Server-side only — never expose this in client code
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database password (for direct SQL / pooler connections)
SUPABASE_DB_PASSWORD=your-db-password

# Pooler connection string (for scripts)
# Format: postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://postgres.your-project-ref:your-db-password@aws-0-eu-west-1.pooler.supabase.com:5432/postgres
